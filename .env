# ========== تنظیمات پایه ==========
SECRET_KEY=django-insecure-by-j7ch_*rhnyt7dkyxk8mr-srm*y62&_u)lp973ceve^9@9k0
DEBUG=True
ENVIRONMENT=development
ALLOWED_HOSTS=127.0.0.1 localhost vakiljuy.ir www.vakiljuy.ir 37.32.10.243
# ========== دیتابیس (PostgreSQL برای پروداکشن) ==========
DB_ENGINE=django.db.backends.postgresql
DB_NAME=dadvar_db
DB_USER=dadvar_user
DB_PASSWORD=your_strong_password_here
DB_HOST=postgres
DB_PORT=5432

# ========== دیتابیس SQLite برای توسعه (اختیاری) ==========
# برای محیط توسعه می‌تونی از SQLite استفاده کنی
DEV_DB_ENGINE=django.db.backends.sqlite3
DEV_DB_NAME=db.sqlite3

# ========== امنیت ==========
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ========== Cache (Redis) ==========
REDIS_URL=redis://redis:6379/1
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache

# ========== درگاه پرداخت زرین‌پال ==========
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=False
ZARINPAL_DESCRIPTION=پرداخت اشتراک سامانه دادور

# ========== ایمیل (برای ارسال ایمیل به وکلا) ==========
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SAMANEH DADVAR <noreply@dadvar.ir>

# ========== تنظیمات سئو و سایت ==========
SITE_NAME=دادور
SITE_DOMAIN=dadvar.ir
SITE_URL=https://dadvar.ir
DEFAULT_META_TITLE=دادور | سامانه تخصصی وکلای ایران
DEFAULT_META_DESCRIPTION=بهترین وکلای طلاق، مهریه، کیفری و حقوقی در تهران و سایر شهرها

# ========== داکر ==========
DJANGO_SETTINGS_MODULE=dadvar.settings
PYTHONUNBUFFERED=1

# ========== ابزارهای جانبی ==========
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_PORT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# ========== لاگ‌ها ==========
LOG_LEVEL=INFO